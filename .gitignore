config/jobspy.yml
config/company_criteria.yml
# personal evaluation criteria (your rubric/fit) — commit the .example versions instead
config/rubric.yml
config/company_fit.yml
# large ATS company corpus + survey output (third-party / regenerable — not redistributed)
data/ats-companies/
data/survey/
