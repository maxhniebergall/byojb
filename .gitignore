# Custom additions (NEW components)
# Python venv for JobSpy ingestion (machine-specific)
.venv/
# generated by `npm run jobspy:refresh` (job data)
data/jobspy-cache.json
# per-company fit briefs from the finder's vetting step (your job-search data)
data/company-fit/
# live user configs (your search terms / criteria) — commit the .example versions instead
config/jobspy.yml
config/company_criteria.yml
# personal evaluation criteria (your rubric/fit) — commit the .example versions instead
config/rubric.yml
config/company_fit.yml
# large ATS company corpus + survey output (third-party / regenerable — not redistributed)
data/ats-companies/
data/survey/
# PERSONAL registry layer (relevance scores, fit, decisions) — keep private
data/companies-personal.jsonl
# NOTE: data/company-research.jsonl + data/company-research/ are the SHAREABLE objective
# layer and are intentionally NOT ignored (committed for a public repo).
# POSTINGS registry — ALL of it is private. Unlike company research notes (LLM-written
# summaries), posting bodies are verbatim third-party JDs = live scraped job data, which the
# data contract says NOT to redistribute. The whole dataset is regenerable via `node scan.mjs`.
data/postings/
data/posting-research.jsonl
data/posting-research/
data/postings-personal.jsonl
data/posting-fit/
# bulk-curated test-case set (validation artifact)
data/company-tests.json
# local state backups (contains personal data — never commit)
backups/
# agent (Antigravity/Gemini) scratch working dir — throwaway batch/score JSON
scratch/
